{
  "name": "sqldev",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --config vite.config.mjs",
    "build": "vue-tsc --noEmit && vite build --config vite.config.mjs",
    "preview": "vite preview --config vite.config.mjs",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint src --ext .ts,.vue --config eslint.config.mjs",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.8",
    "pinia": "^2.2.6",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.2",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/tsconfig": "^0.7.0",
    "@vue/eslint-config-prettier": "^10.1.0",
    "@vue/eslint-config-typescript": "^14.5.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.18.0",
    "eslint-plugin-vue": "^9.32.0",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vue-tsc": "^2.1.10",
    "globals": "^15.14.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
