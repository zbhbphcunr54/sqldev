# Frontend runtime config. Copy to .env.local for local development only.
# Do not commit real keys; GitHub Pages / CI should inject these values from secrets.

# Supabase project URL, for example: https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Supabase public anon / publishable key. Never use service_role in browser code.
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Optional frontend request timeout in milliseconds. Default is 30000, max is 120000.
VITE_API_TIMEOUT_MS=30000

# Optional local ports.
VITE_DEV_PORT=5173
VITE_PREVIEW_PORT=4173

# Optional: set to 1 to emit production sourcemaps for staging diagnostics.
VITE_BUILD_SOURCEMAP=0

# Supabase Edge Function secrets are configured with `supabase secrets set`, not here:
# CORS_PRIMARY_ORIGIN, CORS_ALLOWED_ORIGINS, ALLOW_LOCALHOST_ORIGIN
# CONVERT_RATE_LIMIT_MAX_REQUESTS, CONVERT_RATE_LIMIT_WINDOW_MS, CONVERT_RATE_LIMIT_TRACK_MAX
# ZIWEI_ALLOWED_EMAILS, ZIWEI_AI_API_KEY, ZIWEI_AI_BASE_URL, ZIWEI_AI_MODEL
